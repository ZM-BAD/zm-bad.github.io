<div class="widget">
    <form id="search-form" class="search-form">
      <input id="query" type="text" placeholder="Search" class="search-form-input">
    </form>
</div>
<script type="text/javascript">
document.addEventListener('DOMContentLoaded', function() {
    function escapeHtml(str) {
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(str));
        return div.innerHTML;
    }

    function escapeRegex(str) {
        return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    function findPosts(words, postsData) {
        var matched = [];
        postsData.forEach(function(post) {
            var content = [post.title, post.keywords].join(" ");
            for (var i = 0; i < words.length; i++) {
                if (!words[i]) continue;
                if (new RegExp(escapeRegex(words[i]), 'i').test(content)) {
                    matched.push(post);
                    break;
                }
            }
        });
        return matched;
    }

    function showPosts(posts) {
        var container = document.querySelector('.content_container');
        container.innerHTML = '';
        if (posts.length > 0) {
            posts.forEach(function(post) {
                var div = document.createElement('div');
                div.className = 'post';

                var h2 = document.createElement('h2');
                h2.className = 'post-title';
                var a = document.createElement('a');
                a.href = post.url;
                a.textContent = post.title;
                h2.appendChild(a);
                div.appendChild(h2);

                var meta = document.createElement('div');
                meta.className = 'post-meta';
                meta.innerHTML = '<i class="icon-post-date"> ' + escapeHtml(post.date || '') + '</i>';
                div.appendChild(meta);

                var content = document.createElement('div');
                content.className = 'post-content';
                content.textContent = post.summary || '';
                div.appendChild(content);

                var readmore = document.createElement('p');
                readmore.className = 'readmore';
                var link = document.createElement('a');
                link.href = post.url;
                link.textContent = '阅读更多';
                readmore.appendChild(link);
                div.appendChild(readmore);

                container.appendChild(div);
            });
        } else {
            var h4 = document.createElement('h4');
            h4.textContent = '您输入的关键词没有搜索结果，请更换关键词！ O(∩_∩)O~';
            container.appendChild(h4);
        }
        container.style.display = '';
    }

    var form = document.getElementById('search-form');
    var queryInput = document.getElementById('query');

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        var query = queryInput.value;
        var words = query.split(/\s+/);
        queryInput.blur();
        queryInput.disabled = true;
        document.querySelector('.content_container').style.display = 'none';

        fetch('{{ "/assets/data/posts.json" | prepend: site.baseurl }}')
            .then(function(res) { return res.json(); })
            .then(function(data) {
                var matched = findPosts(words, data);
                showPosts(matched);
            })
            .catch(function() {
                var container = document.querySelector('.content_container');
                container.innerHTML = '';
                var h4 = document.createElement('h4');
                h4.textContent = '搜索请求失败，请稍后重试。';
                container.appendChild(h4);
                container.style.display = '';
            })
            .finally(function() {
                queryInput.disabled = false;
            });

        return false;
    });
});
</script>
